{
  "regions": ["iad1"],
  "framework": "nextjs",
  "headers": [
    {
      "source": "/api/dashboard/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
